{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git worktree list)",
      "Bash(git worktree list:*)",
      "Bash(git check-ignore:*)",
      "Bash(git config --get:*)",

      "Bash(git fetch)",
      "Bash(git fetch:*)",
      "Bash(git rebase origin/main)",
      "Bash(git rebase origin/main:*)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",

      "Bash(git push origin feature/*)",
      "Bash(git push origin HEAD:feature/*)",

      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(echo:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm run:*)",
      "Bash(netlify:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",

      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master)",
      "Bash(git push origin master:*)",
      "Bash(git push:*main)",
      "Bash(git push:*master)",

      "Bash(git reset --hard:*)",

      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf $HOME:*)"
    ]
  }
}
