# =========================================================
# 데이터베이스 (Netlify DB 자동 주입)
# =========================================================
NETLIFY_DATABASE_URL=postgres://...

# =========================================================
# JWT 인증 (★ 운영시 강력한 랜덤 문자열로 교체)
# 생성: openssl rand -base64 64
# =========================================================
JWT_SECRET=change-me-to-a-strong-random-64-char-string-please
JWT_EXPIRES_IN=7d

# 관리자 전용 JWT
ADMIN_JWT_SECRET=change-me-admin-different-secret-key-also-64-chars
ADMIN_JWT_EXPIRES_IN=2h

# =========================================================
# 관리자 초기 계정 (DB 시드용 — STEP 9에서 사용)
# =========================================================
ADMIN_DEFAULT_ID=admin
ADMIN_DEFAULT_PW=ChangeMe1234!

# =========================================================
# 보안 설정
# =========================================================
BCRYPT_ROUNDS=10
LOGIN_MAX_FAIL=5
LOGIN_LOCK_MINUTES=30

# =========================================================
# 개발 환경 (로컬 테스트용)
# =========================================================
NODE_ENV=development