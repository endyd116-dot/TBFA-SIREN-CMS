# =========================================================
# 데이터베이스 (Netlify DB 자동 주입)
# =========================================================
NETLIFY_DATABASE_URL=postgres://...

# =========================================================
# JWT 인증 (★ 운영시 강력한 랜덤 문자열로 교체)
# 생성: openssl rand -base64 64
# =========================================================
JWT_SECRET=change-me-to-a-strong-random-64-char-string-please
JWT_EXPIRES_IN=7d

# 관리자 전용 JWT
ADMIN_JWT_SECRET=change-me-admin-different-secret-key-also-64-chars
ADMIN_JWT_EXPIRES_IN=2h

# =========================================================
# 관리자 초기 계정 (DB 시드용 — STEP 9에서 사용)
# =========================================================
ADMIN_DEFAULT_ID=admin
ADMIN_DEFAULT_PW=ChangeMe1234!

# =========================================================
# 보안 설정
# =========================================================
BCRYPT_ROUNDS=10
LOGIN_MAX_FAIL=5
LOGIN_LOCK_MINUTES=30

# =========================================================
# 개발 환경 (로컬 테스트용)
# =========================================================
NODE_ENV=development

# =========================================================
# Phase 9 — Aligo SMS·카카오 알림톡 (선결제 충전형)
# A 채팅(SMS) + B 채팅(알림톡) 공유 — 인증 키는 동일 계정
# =========================================================
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=                       # 등록 발신번호 (협회 대표번호, - 제거)
ALIGO_KAKAO_CHANNEL_ID=             # 협회 카카오톡 채널 senderkey

# ★ 2026-05-16: 카카오 알림톡 프록시 (Oracle Cloud Free VM 고정 IP)
# Netlify Functions 변동 IP → 프록시 → 알리고 (알리고는 프록시 IP만 화이트리스트)
# 설정되어 있으면 sendAligoAlimtalk가 프록시 경유로 호출. 비어있으면 직접 호출.
# 구축 가이드: proxy-server/SETUP.md
ALIGO_PROXY_URL=                    # 예: http://158.180.123.45:8080/aligo/alimtalk
ALIGO_PROXY_SECRET=                 # 프록시 .env의 PROXY_SECRET과 동일 값

# 알림톡 템플릿 ID — 카카오 심사 통과 후 입력 (미입력 시 placeholder 동작)
ALIGO_TEMPLATE_BILLING_FAILED=
ALIGO_TEMPLATE_CARD_EXPIRING=

# 테스트 모드 (true 시 실 발송 X, 콘솔 로그 + status=sent 기록만)
NOTIFICATION_TEST_MODE=false