# =========================================================
# 데이터베이스 (Netlify DB 자동 주입)
# =========================================================
NETLIFY_DATABASE_URL=postgres://...

# =========================================================
# JWT 인증 (★ 운영시 강력한 랜덤 문자열로 교체)
# 생성: openssl rand -base64 64
# =========================================================
JWT_SECRET=change-me-to-a-strong-random-64-char-string-please
JWT_EXPIRES_IN=7d

# 관리자 전용 JWT
ADMIN_JWT_SECRET=change-me-admin-different-secret-key-also-64-chars
ADMIN_JWT_EXPIRES_IN=2h

# =========================================================
# 관리자 초기 계정 (DB 시드용 — STEP 9에서 사용)
# =========================================================
ADMIN_DEFAULT_ID=admin
ADMIN_DEFAULT_PW=ChangeMe1234!

# =========================================================
# 보안 설정
# =========================================================
BCRYPT_ROUNDS=10
LOGIN_MAX_FAIL=5
LOGIN_LOCK_MINUTES=30

# =========================================================
# 개발 환경 (로컬 테스트용)
# =========================================================
NODE_ENV=development

# =========================================================
# SOLAPI(솔라피) — SMS·LMS·MMS·카카오 알림톡 (2026-05-23 알리고+Oracle프록시 대체)
# API Key 인증(HMAC-SHA256) — 발신 IP 화이트리스트 불필요 → Netlify 직접 호출
# =========================================================
SOLAPI_API_KEY=                     # 솔라피 콘솔 API Key (허용 IP "모든 IP 허용")
SOLAPI_API_SECRET=                  # 솔라피 API Secret (발급 시 1회만 노출)
SOLAPI_SENDER=                      # 등록 발신번호 (협회 대표번호, - 제거)

# 카카오 알림톡 — 발신프로필 키 + 템플릿별 templateId (카카오 승인 후 입력. 미입력 시 placeholder)
SOLAPI_KAKAO_PFID=                  # 솔라피 카카오 채널 연동 시 발급(KA01PF...)
SOLAPI_TPL_BILLING_FAILED=          # 정기 결제 실패
SOLAPI_TPL_CARD_EXPIRING=           # 등록 카드 만료 안내
SOLAPI_TPL_BILLING_SUCCESS=         # 정기 후원금 출금 완료 안내
SOLAPI_TPL_BILLING_UPCOMING=        # 정기 후원금 자동 출금 예정 안내
SOLAPI_TPL_RECEIPT=                 # 연간 기부금 영수증 발급 안내
SOLAPI_TPL_DONOR_CHANGE=            # 후원 정보 변경 처리 완료

# 테스트 모드 (true 시 실 발송 X, 콘솔 로그 + status=sent 기록만)
NOTIFICATION_TEST_MODE=false